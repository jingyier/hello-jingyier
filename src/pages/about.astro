---
import SiteShell from "@components/SiteShell.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  title="About · jingyier"
  description="About jingyier and this personal static site."
  pathname="/about"
>
  <SiteShell title="关于" className="about-shell">
    <section class="about-card glass-panel">
      <div class="about-cover" aria-hidden="true">
        <img src="/images/silent-bloom/backgrounds/breathing-path.webp" alt="" />
      </div>
      <img class="about-avatar" src="/images/silent-bloom/character/meditating-figure.webp" alt="" />
      <div class="about-copy">
        <p class="eyebrow">Hello world, I'm jingyier</p>
        <h1>关于我</h1>
        <p>
          这是 jingyier 的个人网站。它先用来放摘录、短记、一些小工具和正在试验的页面。
        </p>
        <p>
          静默花园会继续保留，但它只是其中一个房间。首页会更像个人索引，而不是把一个互动原型解释成整座网站。
        </p>
        <p class="contact-line">Contact placeholder: hello@jingyier.com / 或换成你的社交主页</p>
      </div>
      <div class="segment-tabs" role="tablist" aria-label="关于内容">
        <button type="button" aria-selected="true">自我介绍</button>
        <button type="button" aria-selected="false">研究动态</button>
      </div>
    </section>
  </SiteShell>
</BaseLayout>
