---
import SiteHeader from "@components/SiteHeader.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  title="About · jingyier"
  description="About jingyier and this personal static site."
  pathname="/about"
>
  <main class="site-shell">
    <SiteHeader />
    <section class="about-layout">
      <div>
        <p class="eyebrow">About</p>
        <h1>关于这里</h1>
      </div>
      <div class="about-copy">
        <p>
          这是 jingyier 的个人网站。它先用来放摘录、短记、一些小工具和正在试验的页面。
        </p>
        <p>
          静默花园会继续保留，但它只是其中一个房间。首页会更像个人索引，而不是把一个互动原型解释成整座网站。
        </p>
        <p class="contact-line">Contact placeholder: hello@jingyier.com / 或换成你的社交主页</p>
      </div>
      <div class="about-figure" role="img" aria-label="A quiet glass garden mark made with layered CSS shapes">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </section>
  </main>
</BaseLayout>
