---
import { getCollection } from "astro:content";
import NoteList from "@components/NoteList.astro";
import SectionHeader from "@components/SectionHeader.astro";
import SiteHeader from "@components/SiteHeader.astro";
import BaseLayout from "@layouts/BaseLayout.astro";

const notes = (await getCollection("notes")).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Notes · jingyier" description="Personal notes on moods, design, development, and small systems." pathname="/notes">
  <main class="site-shell">
    <SiteHeader />
    <section class="page-intro">
      <p class="eyebrow">Notes</p>
      <h1>暗室札记</h1>
      <p class="lede">灵感、设计判断和开发取舍像被收进抽屉的纸片，等待某一次视角旋转时露出边缘。</p>
    </section>

    <section class="content-section">
      <SectionHeader
        eyebrow="Journal"
        title="低噪声的内容记录"
        summary="每条札记保留日期、标签和摘要，仍然适合扩展到详情页、搜索、RSS 和轻量 JSON。"
      />
      <NoteList items={notes} />
    </section>
  </main>
</BaseLayout>
