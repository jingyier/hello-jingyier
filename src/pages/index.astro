---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import SiteShell from "@components/SiteShell.astro";
import homeData from "../content/home.json";
import homeScriptUrl from "../scripts/home.js?url";

const notes = (await getCollection("notes")).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
const works = (await getCollection("work")).filter((item) => item.data.featured).slice(0, 2);
---

<BaseLayout
  title="jingyier"
  description="一些摘录、记录、实验和小工具。"
  pathname="/"
>
  <SiteShell title="jingyier" className="home-treasure">
    <div data-home-page>
      <section class="home-search-hero" aria-label="jingyier search">
        <div class="treasure-search home-search" role="search">
          <span aria-hidden="true"></span>
          <input type="search" placeholder="搜寻标题、描述或标签..." aria-label="搜索站内内容" />
        </div>
      </section>

      <section class="home-dashboard" aria-label="jingyier personal dashboard">
        <article class="glass-panel profile-panel">
          <img class="profile-avatar" src="/images/silent-bloom/character/meditating-figure.webp" alt="" />
          <div class="profile-copy">
            <h1>jingyier</h1>
            <p>Programmer needs to be trusted.</p>
          </div>
          <div class="profile-stats" aria-label="站点统计">
            <span><strong>{notes.length}</strong><small>近记</small></span>
            <span><strong>{works.length}</strong><small>项目</small></span>
            <span><strong>{homeData.quotes.length}</strong><small>摘录</small></span>
          </div>
          <div class="card-footer-info" id="card-footer-info">
            <div class="card-footer-cell">
              <span>本地时间</span>
              <strong id="local-time" aria-live="polite">--:--:--</strong>
            </div>
            <div class="card-footer-cell card-footer-weather">
              <span>天气</span>
              <strong id="weather-info" aria-live="polite">加载中</strong>
            </div>
          </div>
        </article>

        <article class="glass-panel home-music-card meting-card">
          <div class="home-music-glass" data-home-music>
            <img class="home-music-art" data-home-music-cover src="/images/silent-bloom/backgrounds/crystal-resonance.webp" alt="" />
            <div class="home-music-main">
              <div class="home-music-copy">
                <a class="home-music-title-link" href="/music" data-home-music-title>云端乐律</a>
                <div class="home-music-progress">
                  <span data-home-music-current>00:00</span>
                  <button type="button" data-home-music-seek aria-label="音乐播放进度">
                    <i data-home-music-bar></i>
                  </button>
                </div>
              </div>
              <div class="home-music-controls">
                <button type="button" data-home-music-prev aria-label="上一首">‹</button>
                <button class="home-music-play" type="button" data-home-music-toggle aria-label="播放或暂停"><span></span></button>
                <button type="button" data-home-music-next aria-label="下一首">›</button>
              </div>
            </div>
          </div>
        </article>
      </section>

      <section class="feature-mosaic" aria-label="内容入口">
        <article class="feature-tile feature-tile-large message-entry-tile">
          <button type="button" data-open-message-board aria-haspopup="dialog">
            <span>Message board</span>
            <h2>留言板</h2>
            <p>打开木框留言板，查看带时间戳的真实留言。</p>
          </button>
        </article>
        <article class="feature-tile feature-tile-wide">
          <a href="/garden">
            <h2>静默花园</h2>
            <p>触摸、播种、呼吸与夜园保存。</p>
          </a>
        </article>
        <article class="feature-tile">
          <a href="/work">
            <span>Records</span>
            <h2>{works[0]?.data.title ?? "项目索引"}</h2>
            <p>{works[0]?.data.summary ?? "正在成形的实验和页面。"}</p>
          </a>
        </article>
      </section>

      <dialog class="message-board-dialog" id="messages" aria-labelledby="message-board-title" data-message-dialog>
        <div class="message-window">
          <div class="message-window-controls" aria-label="留言板窗口控制">
            <button type="button" data-toggle-message-fullscreen aria-label="切换全屏">□</button>
            <button type="button" data-close-message-board aria-label="关闭留言板">×</button>
          </div>
          <section class="message-window-inner">
            <div class="message-window-head">
              <span>Message board</span>
              <h2 id="message-board-title">留言板</h2>
              <p data-message-feedback>留言会先审核，公开后显示在这里。</p>
            </div>
            <ul class="message-list" data-message-list aria-live="polite"></ul>
            <div class="message-pagination" aria-label="留言分页">
              <button type="button" data-message-prev>上一页</button>
              <span data-message-page-status>1 / 1</span>
              <button type="button" data-message-next>下一页</button>
            </div>
            <form class="message-form" data-message-form>
              <input class="message-honeypot" name="website" type="text" tabindex="-1" autocomplete="off" aria-hidden="true" />
              <label>
                <input name="message" type="text" maxlength="120" autocomplete="off" placeholder="写下想留下的一句。" aria-label="写一句留言" />
              </label>
              <button type="submit">留下</button>
            </form>
          </section>
        </div>
      </dialog>
    </div>
  </SiteShell>

  <script type="application/json" id="home-data" set:html={JSON.stringify(homeData)} />
  <script type="module" src={homeScriptUrl}></script>
</BaseLayout>
