---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  title="jingyier"
  description="jingyier is a lightweight static site shaped for art, notes, work, and quiet expansion."
>
  <main class="site-shell">
    <header class="topbar" aria-label="Site navigation">
      <a class="brand" href="/">jingyier</a>
      <nav>
        <a href="/work">Work</a>
        <a href="/notes">Notes</a>
        <a href="/about">About</a>
      </nav>
    </header>

    <section class="hero" aria-labelledby="hero-title">
      <p class="eyebrow">Static first · artful by default</p>
      <h1 id="hero-title">jingyier</h1>
      <p class="lede">
        一个轻量、克制、可扩展的静态网站基线，用来承载作品、札记、影像与后续的小型动态能力。
      </p>
      <div class="hero-actions" aria-label="Primary actions">
        <a class="text-link" href="/work">Explore work</a>
        <a class="text-link" href="/notes">Read notes</a>
      </div>
    </section>

    <section class="baseline" aria-label="Project baseline">
      <p>Astro static output</p>
      <p>Cloudflare Pages ready</p>
      <p>Vercel JSON API ready</p>
    </section>
  </main>
</BaseLayout>
