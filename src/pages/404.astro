---
import SiteHeader from "@components/SiteHeader.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="404 · jingyier" description="This page does not exist on jingyier yet." pathname="/404">
  <main class="site-shell">
    <SiteHeader />
    <section class="page-intro">
      <p class="eyebrow">404</p>
      <h1>这里还没有内容</h1>
      <p class="lede">可能是链接写错了，也可能只是这个页面还没整理出来。先回到首页，或者去看看最近的记录。</p>
      <div class="hero-actions">
        <a class="text-link" href="/">Back home</a>
        <a class="text-link" href="/notes">View notes</a>
      </div>
    </section>
  </main>
</BaseLayout>
