---
import "@styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  pathname?: string;
}

const {
  title = "jingyier",
  description = "A lightweight, artful static site for jingyier.",
  image = "/favicon.svg",
  pathname = Astro.url.pathname
} = Astro.props;

const canonical = new URL(pathname, Astro.site ?? Astro.url.origin);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#080b12" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta property="og:site_name" content="jingyier" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, Astro.site ?? Astro.url.origin)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site ?? Astro.url.origin)} />

    <title>{title}</title>
  </head>
  <body>
    <div class="site-ambient-backdrop" aria-hidden="true">
      <div class="ambient-slides">
        <img class="ambient-slide ambient-slide-1" src="/images/ling-cage-background.png" alt="" />
        <img class="ambient-slide ambient-slide-2" src="/images/ling-cage-background-2.png" alt="" />
        <img class="ambient-slide ambient-slide-3" src="/images/ling-cage-background-3.png" alt="" />
        <img class="ambient-slide ambient-slide-4" src="/images/ling-cage-background-4.png" alt="" />
      </div>
      <span class="site-frost"></span>
      <div class="firefly-field">
        <span class="firefly firefly-1"></span>
        <span class="firefly firefly-2"></span>
        <span class="firefly firefly-3"></span>
        <span class="firefly firefly-4"></span>
        <span class="firefly firefly-5"></span>
        <span class="firefly firefly-6"></span>
        <span class="firefly firefly-7"></span>
        <span class="firefly firefly-8"></span>
        <span class="firefly firefly-9"></span>
        <span class="firefly firefly-10"></span>
        <span class="firefly firefly-11"></span>
        <span class="firefly firefly-12"></span>
        <span class="firefly firefly-13"></span>
        <span class="firefly firefly-14"></span>
        <span class="firefly firefly-15"></span>
        <span class="firefly firefly-16"></span>
        <span class="firefly firefly-17"></span>
        <span class="firefly firefly-18"></span>
        <span class="firefly firefly-19"></span>
        <span class="firefly firefly-20"></span>
        <span class="firefly firefly-21"></span>
        <span class="firefly firefly-22"></span>
        <span class="firefly firefly-23"></span>
        <span class="firefly firefly-24"></span>
      </div>
    </div>
    <slot />
  </body>
</html>
