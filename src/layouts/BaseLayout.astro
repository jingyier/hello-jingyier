---
import "@styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  pathname?: string;
}

const {
  title = "jingyier",
  description = "A lightweight, artful static site for jingyier.",
  image = "/favicon.svg",
  pathname = Astro.url.pathname
} = Astro.props;

const canonical = new URL(pathname, Astro.site ?? Astro.url.origin);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f4f0e8" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta property="og:site_name" content="jingyier" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, Astro.site ?? Astro.url.origin)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site ?? Astro.url.origin)} />

    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
