---
interface NoteItem {
  id: string;
  slug?: string;
  data: {
    title: string;
    date: Date;
    summary: string;
    category?: string;
    tags: string[];
    featured: boolean;
  };
  body: string;
  Content: any;
}

interface Props {
  items: NoteItem[];
}

const { items } = Astro.props;
const formatter = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit"
});
---

<div class="note-archive note-list">
  {
    items.map((item) => {
      const category = item.data.category ?? item.data.tags[0] ?? "未分类";
      const Body = item.Content;

      return (
        <article
          class:list={["article-row", "note-entry", item.data.featured && "is-featured"]}
          id={item.slug ?? item.id}
          data-archive-card
          data-expanded="false"
        >
          <button class="article-card-toggle" type="button" data-article-toggle aria-expanded="false">
            <span class="article-row-copy">
              <span class="article-title">{item.data.title}</span>
              <span class="article-row-meta">
                <time datetime={item.data.date.toISOString()}>{formatter.format(item.data.date)}</time>
                <span>{category}</span>
              </span>
              <span class="article-summary">{item.data.summary}</span>
            </span>
          </button>
          <div class="article-fulltext">
            <Body />
          </div>
        </article>
      );
    })
  }
</div>
