---
interface WorkItem {
  slug: string;
  data: {
    title: string;
    year: number;
    type: string;
    summary: string;
    cover: string;
    coverAlt: string;
    featured: boolean;
  };
}

interface Props {
  items: WorkItem[];
}

const { items } = Astro.props;
---

<div class="work-grid">
  {
    items.map((item) => (
      <article class="work-item">
        <img src={item.data.cover} alt={item.data.coverAlt} loading="lazy" />
        <div class="work-copy">
          <p class="meta-line">
            {item.data.year} / {item.data.type}
            {item.data.featured && <span>Featured</span>}
          </p>
          <h3>{item.data.title}</h3>
          <p>{item.data.summary}</p>
        </div>
      </article>
    ))
  }
</div>
