---
interface WorkItem {
  id: string;
  slug?: string;
  data: {
    title: string;
    year: number;
    type: string;
    summary: string;
    category?: string;
    tags?: string[];
    cover: string;
    coverAlt: string;
    featured: boolean;
  };
}

interface Props {
  items: WorkItem[];
}

const { items } = Astro.props;
---

<div class="work-archive">
  {
    items.map((item) => {
      const itemId = item.slug ?? item.id;
      const href = itemId === "silent-bloom.md" || itemId === "silent-bloom" ? "/garden" : `/work#${itemId}`;
      const category = item.data.category ?? item.data.type;

      return (
        <article class:list={["article-row", "work-entry", item.data.featured && "is-featured"]} id={itemId}>
          <div class="article-row-meta">
            <time>{item.data.year}</time>
            <span>{category}</span>
          </div>
          <div class="article-row-copy">
            <h2><a href={href}>{item.data.title}</a></h2>
            <p>{item.data.summary}</p>
          </div>
        </article>
      );
    })
  }
</div>
