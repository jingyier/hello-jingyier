---
const links = [
  { href: "/notes", label: "Notes" },
  { href: "/work", label: "Work" },
  { href: "/garden", label: "Garden" },
  { href: "/about", label: "About" }
];

interface Props {
  variant?: "default" | "spatial";
}

const { variant = "default" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header class:list={["site-header", variant === "spatial" && "site-header-spatial"]} aria-label="Site navigation">
  <a class="site-brand" href="/" aria-label="jingyier home">jingyier</a>
  <nav>
    {
      links.map((link) => (
        <a href={link.href} aria-current={currentPath.startsWith(link.href) ? "page" : undefined}>
          {link.label}
        </a>
      ))
    }
  </nav>
</header>
